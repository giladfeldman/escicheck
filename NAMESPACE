# S3 class and methods
export(is.effectcheck)
S3method(print, effectcheck)
S3method(summary, effectcheck)
S3method(print, summary.effectcheck)
S3method(plot, effectcheck)
S3method("[", effectcheck)
S3method(rbind, effectcheck)

